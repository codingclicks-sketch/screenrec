{
  "manifest_version": 3,
  "name": "VeoRec — Screen Recorder & Share",
  "version": "1.9.0",
  "description": "Record your screen, camera & mic, then get an instant shareable link with AI transcription. Free & fast — a Loom alternative.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://veorec.com/*", "https://www.veorec.com/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "VeoRec — Record your screen",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
